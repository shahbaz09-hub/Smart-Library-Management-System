{
  "info": {
    "name": "Smart Library Backend",
    "_postman_id": "d3f5e2c1-0000-4a1b-9f8b-123456789abc",
    "description": "Health, Login and Get Books requests for local testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","health"]
        }
      }
    },
    {
      "name": "Login (get token)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@demo.com\",\n  \"password\": \"demo123\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/auth/login",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["auth","login"]
        }
      }
    },
    {
      "name": "Get Books (authenticated)",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": {
          "raw": "http://localhost:8080/api/books",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api","books"]
        }
      }
    }
  ],
  "variable": [
    { "key": "token", "value": "" }
  ]
}
